SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Optional: use LLM for prompt parsing (extracts all fields + any extra properties from prompt)
OPENAI_API_KEY=your_openai_api_key

# Production (Railway): comma-separated browser origins allowed to call the API
# Example: https://your-app.vercel.app
ALLOWED_ORIGINS=

# Optional: allow Vercel production + preview URLs (full Origin match; use in Railway if needed)
# ALLOWED_ORIGIN_REGEX=^https://[\w.-]+\.vercel\.app$
# Or list one site explicitly:
# ALLOWED_ORIGINS=https://ai-architecture-app-psi.vercel.app
